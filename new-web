  <script>
    // 检查图片加载状态
    document.addEventListener('DOMContentLoaded', function() {
      const images = document.querySelectorAll('img');

      images.forEach(img => {
        // 图片加载失败时显示提示
        img.addEventListener('error', function() {
          this.alt = '图片加载失败';
          this.style.border = '2px solid #ff4444';
          this.style.backgroundColor = '#fef0f0';
          this.style.padding = '20px 0';
          this.style.fontSize = '14px';
          this.style.color = '#ff4444';
          this.style.display = 'flex';
          this.style.alignItems = 'center';
          this.style.justifyContent = 'center';
        });
      });

      // 模拟实时数据更新
      setInterval(() => {
        const secondsElement = document.querySelector('.font-medium:last-of-type');
        if (secondsElement) {
          const text = secondsElement.textContent;
          const match = text.match(/(\d+)分(\d+)秒/);
          if (match) {
            let minutes = parseInt(match[1]);
            let seconds = parseInt(match[2]) + 1;

            if (seconds >= 60) {
              seconds = 0;
              minutes += 1;
            }

            secondsElement.textContent = `${minutes}分${seconds.toString().padStart(2, '0')}秒`;
          }
        }
      }, 1000);
    });
  </script>

